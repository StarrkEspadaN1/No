using System;

namespace GeometryApp
{
    /// <summary>Абстрактная геометрическая фигура.</summary>
    public abstract class GeometricFigure
    {
        public abstract double GetArea();
        public abstract double GetPerimeter();
    }

    public class Triangle : GeometricFigure
    {
        private double a, b, c;
        public Triangle(double a, double b, double c)
        {
            if (a <= 0 || b <= 0 || c <= 0 || a + b <= c || a + c <= b || b + c <= a)
                throw new ArgumentException("Некорректные стороны.");
            this.a = a; this.b = b; this.c = c;
        }
        public override double GetArea()
        {
            double p = (a + b + c) / 2;
            return Math.Sqrt(p * (p - a) * (p - b) * (p - c));
        }
        public override double GetPerimeter() => a + b + c;
    }

    public class Square : GeometricFigure
    {
        private double side;
        public Square(double side) { if (side <= 0) throw new ArgumentException(); this.side = side; }
        public override double GetArea() => side * side;
        public override double GetPerimeter() => 4 * side;
    }

    public class Rhombus : GeometricFigure
    {
        private double d1, d2;
        public Rhombus(double d1, double d2) { this.d1 = d1; this.d2 = d2; }
        public override double GetArea() => (d1 * d2) / 2;
        public override double GetPerimeter()
        {
            double side = Math.Sqrt(Math.Pow(d1 / 2, 2) + Math.Pow(d2 / 2, 2));
            return 4 * side;
        }
    }

    public class Rectangle : GeometricFigure
    {
        private double w, h;
        public Rectangle(double w, double h) { this.w = w; this.h = h; }
        public override double GetArea() => w * h;
        public override double GetPerimeter() => 2 * (w + h);
    }

    public class Parallelogram : GeometricFigure
    {
        private double baseSide, side, angleDeg;
        public Parallelogram(double baseSide, double side, double angleDeg)
        {
            this.baseSide = baseSide;
            this.side = side;
            this.angleDeg = angleDeg;
        }
        public override double GetArea()
        {
            double rad = angleDeg * Math.PI / 180.0;
            return baseSide * side * Math.Sin(rad);
        }
        public override double GetPerimeter() => 2 * (baseSide + side);
    }

    public class Trapezoid : GeometricFigure
    {
        private double a, b, h;
        public Trapezoid(double lowerBase, double upperBase, double height)
        {
            a = lowerBase; b = upperBase; h = height;
        }
        public override double GetArea() => (a + b) / 2 * h;
        public override double GetPerimeter()
        {
            double diff = Math.Abs(a - b) / 2;
            double lateral = Math.Sqrt(h * h + diff * diff);
            return a + b + 2 * lateral;
        }
    }

    public class Circle : GeometricFigure
    {
        private double r;
        public Circle(double r) { this.r = r; }
        public override double GetArea() => Math.PI * r * r;
        public override double GetPerimeter() => 2 * Math.PI * r;
    }

    public class Ellipse : GeometricFigure
    {
        private double a, b;
        public Ellipse(double semiMajor, double semiMinor)
        {
            if (semiMajor < semiMinor) throw new ArgumentException();
            a = semiMajor; b = semiMinor;
        }
        public override double GetArea() => Math.PI * a * b;
        public override double GetPerimeter()
        {
            double h = Math.Pow(a - b, 2) / Math.Pow(a + b, 2);
            return Math.PI * (a + b) * (1 + (3 * h) / (10 + Math.Sqrt(4 - 3 * h)));
        }
    }
}
